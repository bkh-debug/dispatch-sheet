rules_version = '2';

// ⚠️ 개발/사내 사용을 위한 임시 규칙입니다.
// 로그인 없이 누구나 이 주소를 알면 데이터를 읽고 쓸 수 있습니다.
// 외부에 공개되지 않는 내부망/사내 링크로만 공유하세요.
// 나중에 더 안전하게 만들고 싶다면 Firebase Authentication을 추가하고
// 아래 allow 조건을 "if request.auth != null;" 로 바꾸면 됩니다.

service cloud.firestore {
  match /databases/{database}/documents {

    match /products/{code} {
      allow read, write: if true;
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }
  }
}
